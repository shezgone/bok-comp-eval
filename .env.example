# LLM API keys for cross-model evaluation.
# Copy to .env (which is gitignored) and fill in.

# --- Korean LLMs ---
HCX_API_KEY=
HCX_BASE_URL=
HCX_MODEL=         # e.g. HCX-005 / HCX-DASH-001 (passed as OPENAI_MODEL when --llm hcx)

# --- Chinese LLMs ---
QWEN_API_KEY=
QWEN_BASE_URL=
QWEN_MODEL=

# --- Frontier closed models (for Tier 1+) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o   # default model for --llm gpt4o
ANTHROPIC_API_KEY=

# --- Open-weight Western (for Tier 2) ---
TOGETHER_API_KEY=

# --- DB connections (must match production agent variable names) ---
TYPEDB_ADDRESS=127.0.0.1:1729
TYPEDB_DATABASE=compensation_regulations

NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j
